# Copy to .env (root). Never commit .env.

# -- Database (Postgres + pgvector; matches docker-compose.yml) --
POSTGRES_SERVER=localhost
POSTGRES_PORT=5433
POSTGRES_DB=vcbrain
POSTGRES_USER=vcbrain
POSTGRES_PASSWORD=vcbrain
DATABASE_URL=postgresql+psycopg://vcbrain:vcbrain@localhost:5433/vcbrain

# -- Browser origins allowed to call the FastAPI API --
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# -- LLM + web enrichment (OpenAI-only per CLAUDE.md; no Anthropic) --
OPENAI_API_KEY=sk-...
TAVILY_API_KEY=tvly-...
# Optional: native GitHub fetcher works keyless; token raises rate limit 10->30 req/min
# GITHUB_TOKEN=ghp_...

# -- Sourcing cron (active by default; modest cadence) --
CRON_ENABLED=true
DISCOVERY_INTERVAL_MIN=60
REFRESH_INTERVAL_MIN=360
CLAIMS_INTERVAL_MIN=15

# -- LangSmith tracing (optional) --
LANGSMITH_API_KEY=lsv2-...
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=vc-brain-sourcing
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
