# Environment: local, staging, production
ENVIRONMENT=local

PROJECT_NAME="not_yet_decided"

# Frontend host (used for CORS)
FRONTEND_HOST=http://localhost:5173
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:5173"

# Backend
SECRET_KEY=changethis

# Postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# Blob storage (S3-compatible; MinIO locally via docker-compose)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=app
S3_REGION=us-east-1

# Observability (optional)
SENTRY_DSN=

# LangGraph service (app/service) — provider + tracing keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# LLM routing (langchain init_chat_model ids, e.g. "openai:gpt-4o-mini")
FAST_LLM_MODEL=openai:gpt-4o-mini
STRONG_LLM_MODEL=openai:gpt-4o
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=my-agent
