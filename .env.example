# Copy to .env (root). Never commit .env.
# One .env serves both backends (backend/ + BE/) against one pgvector DB.

# -- Environment / app (BE/) --
ENVIRONMENT=local
PROJECT_NAME="not_yet_decided"
SECRET_KEY=changethis
FRONTEND_HOST=http://localhost:5173
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:5173"

# -- Database (Postgres + pgvector; matches docker-compose.yml) --
# backend/ reads DATABASE_URL; BE/ builds its URL from the POSTGRES_* parts. Keep them consistent.
POSTGRES_SERVER=localhost
POSTGRES_PORT=5433
POSTGRES_DB=vcbrain
POSTGRES_USER=vcbrain
POSTGRES_PASSWORD=vcbrain
DATABASE_URL=postgresql+psycopg://vcbrain:vcbrain@localhost:5433/vcbrain

# -- Blob storage (MinIO / S3 -- deck PDFs + raw documents) --
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=vcbrain
S3_REGION=us-east-1

# -- LLM + web enrichment (OpenAI-only per CLAUDE.md; no Anthropic) --
OPENAI_API_KEY=sk-...
TAVILY_API_KEY=tvly-...

# -- LangSmith tracing (optional) --
LANGSMITH_API_KEY=lsv2-...
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=vc-brain-sourcing
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com

# -- Observability (optional) --
SENTRY_DSN=
