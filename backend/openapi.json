            "title": "Domain"
          },
          "enabled": {
            "type": "boolean",
            "title": "Enabled"
          },
          "yield_count": {
            "type": "integer",
            "title": "Yield Count"
          }
        },
        "type": "object",
        "required": [
          "name",
          "type",
          "domain",
          "enabled",
          "yield_count"
