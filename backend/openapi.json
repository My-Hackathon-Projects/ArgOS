{
  "openapi": "3.1.0",
  "info": {
    "title": "VC Brain \u2014 Sourcing",
    "version": "0.1.0"
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health",
        "operationId": "health",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/signals": {
      "get": {
        "summary": "List Signals",
        "operationId": "list_signals",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50,
              "title": "Limit"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SignalListItem"
                  },
                  "title": "Response List Signals"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/signals/ingest": {
      "post": {
        "summary": "Ingest",
        "operationId": "ingest",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignalEnvelope"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IngestResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/discovery/run": {
      "post": {
        "summary": "Discovery Run",
        "description": "Hand-trigger a discovery run (thesis \u2192 search \u2192 resolve \u2192 persist). Synchronous (~30-60s).",
        "operationId": "discovery_run",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DiscoveryRunResponse"
                }
              }
            }
          }
        }
      }
    },
    "/founders": {
      "get": {
        "summary": "List Founders",
        "operationId": "list_founders",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/FounderListItem"
                  },
                  "type": "array",
                  "title": "Response List Founders"
                }
              }
            }
          }
        }
      }
    },
    "/founders/{founder_id}": {
      "get": {
        "summary": "Get Founder",
        "operationId": "get_founder",
        "parameters": [
          {
            "name": "founder_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Founder Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FounderDetail"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/sourcing-channels": {
      "get": {
        "summary": "List Channels",
        "operationId": "list_channels",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/ChannelItem"
                  },
                  "type": "array",
                  "title": "Response List Channels"
                }
              }
            }
          }
        }
      }
    },
    "/thesis": {
      "get": {
        "summary": "Get Thesis",
        "operationId": "get_thesis",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ThesisResponse"
                }
              }
            }
          }
        }
      }
    }
  },
